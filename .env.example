PORT=4000
# Optional externally reachable URL. If empty, Settings -> Integrations -> Server reachability
# can set a public hostname; otherwise generated agent URLs fall back to the server's detected IP.
SPECREG_PUBLIC_URL=
SPECREG_AUTH=
# Enable in-app git-pull self-update (POST /admin/update). Off by default when SPECREG_AUTH=required.
SPECREG_SELF_UPDATE=
SPECREG_ADMIN_PASSWORD=admin
# Comma-separated allowed browser origins for secured deployments.
SPECREG_CORS_ORIGINS=
# Login sessions expire after this many hours. API/agent token TTLs are opt-in days.
SPECREG_LOGIN_TOKEN_TTL_HOURS=24
SPECREG_API_TOKEN_TTL_DAYS=
SPECREG_AGENT_TOKEN_TTL_DAYS=
# Failed login/enroll throttling.
SPECREG_AUTH_RATE_LIMIT_MAX=5
SPECREG_AUTH_RATE_LIMIT_WINDOW_SECONDS=900
SPECREG_AUTH_RATE_LIMIT_LOCK_SECONDS=900

# Scheduled registry backups. Set a directory to enable; the server writes a
# consistent SQLite snapshot (+ .sha256 sidecar) every SPECREG_BACKUP_INTERVAL
# seconds and keeps the newest SPECREG_BACKUP_KEEP. Also drives POST /api/v1/admin/backup
# and `npm run backup -w @specregistry/server -- <now|list|verify|restore>`.
SPECREG_BACKUP_DIR=
SPECREG_BACKUP_INTERVAL=86400
SPECREG_BACKUP_KEEP=14

# Optional integrations
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MAX_TOKENS=16000
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=

# Optional CLI specreg generate --write overrides
SPECREG_GENERATE_PROVIDER=
SPECREG_GENERATE_MODEL=
SPECREG_GENERATE_BASE_URL=
SPECREG_GENERATE_API_KEY=
SPECREG_GENERATE_MAX_TOKENS=

# Optional Grafana Cloud/Prometheus remote write via Docker Compose profile "metrics"
ALLOY_PORT=12345
GRAFANA_REMOTE_WRITE_URL=
GRAFANA_REMOTE_WRITE_USERNAME=
GRAFANA_REMOTE_WRITE_PASSWORD=
